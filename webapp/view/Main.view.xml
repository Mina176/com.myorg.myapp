<mvc:View
	controllerName="com.myorg.myapp.controller.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'com/myorg/myapp/model/formatter'
	}">

	<Page
		title="{i18n>appTitle}"
		id="idMainPage">
		<content>
				<List id="empListId" items="{employeeModel>/employees}" >
			<items>
			<StandardListItem id="StandardListItemId" title="{employeeModel>name}"
                description="{employeeModel>position}"
                type="Active"
				press="onStandardListItemPress"
				/>
			</items>
			</List>
		</content>
	</Page>

</mvc:View>