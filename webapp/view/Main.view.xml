<mvc:View
	controllerName="com.myorg.myapp.controller.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"	>
	<Page
		title="{i18n>appTitle}"
		id="idMainPage">
		<subHeader>
            <Toolbar id="idSearchToolbar">
                <SearchField 
                    id="idEmployeeSearchField" 
                    placeholder="Search employee..." 
                    liveChange=".onSearchFieldLiveChange" />
            </Toolbar>
        </subHeader>
		<content>
				<List id="idEmployeesList" items="{employeeModel>/employees}" >
			<items>
			<ObjectListItem id="idObjectListItem"  title="{employeeModel>name}" 
                intro="{employeeModel>position}"
                type="Navigation"
				press="onObjectListItemPress"
				/>
			</items>
			</List>
		</content>
	</Page>

</mvc:View>