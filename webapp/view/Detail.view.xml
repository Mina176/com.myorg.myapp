<mvc:View 
  controllerName="com.myorg.myapp.controller.Detail"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:custom="com.myorg.myapp.control"
  >
  <Page
  id="idDetailPage"
    title="{i18n>titleText}"
    showNavButton="true"
    navButtonPress="onPageNavButtonPress"
    >
    <ObjectHeader
      id="idPositionObjectHeader"
      intro="{employeeModel>department}"
      title="{employeeModel>name}"
      number="{employeeModel>position}"/>

    <Table id="idAttendanceTable"
        items="{employeeModel>attendance}" 
        headerText="Attendance Records"
        noDataText="No attendance records found"
        class="sapUiSmallMarginBeginEnd"
        width="auto"
        >
        <columns>
            <Column id="idDetailDateColumn" hAlign="Center">
                <Text id="idDateHeaderText" text="Date" />
            </Column>
            <Column id="iddetailCheckInColumn" hAlign="Center">
                <Text id="idCheckInText" text="Check In" />
            </Column>
            <Column id="iddetailCheckOutColumn" hAlign="Center">
                <Text id="idCheckOutText" text="Check Out" />
            </Column>
            <Column id="idstatusDetailColumn" hAlign="Center">
                <Text id="idPerformanceText" text="Performance" />
            </Column>
        </columns>
        <items>
            <ColumnListItem id="idDetailColumnListItem">
                <cells>
                <Text id="idDateText" text="{employeeModel>date}" />
                    <Text id="idCheckedInText" text="{employeeModel>checkedIn}" />
                    <Text id="idCheckedOutText" text="{employeeModel>checkedOut}" />
                <custom:EmployeePerformance id="idRatingEmployeePerformance" 
                value="{employeeModel>rating}">
                </custom:EmployeePerformance>    
                </cells>
            </ColumnListItem>
        </items>
    </Table>
  </Page>
</mvc:View>