<mvc:View 
  controllerName="com.myorg.myapp.controller.Detail"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:custom="com.myorg.myapp.control"
  >
  <Page
  id="idDetailPage"
    title="{i18n>titleText}"
    showNavButton="true"
    navButtonPress="onPageNavButtonPress"
    >
    <ObjectHeader
      id="idPositionObjectHeader"
      intro="{employeeModel>department}"
      title="{employeeModel>name}"
      number="{employeeModel>position}"/>

    <Table id="idAttendanceTable"
        autoPopinMode="true"
        fixedLayout="false"
        items="{employeeModel>attendance}" 
        headerText="{i18n>attendanceRecordText}"
        noDataText="{i18n>noAttendanceRecordText}"
        class="sapUiSmallMarginBeginEnd"
        width="auto"
        >
        <columns>
            <Column id="idAttendanceIdColumn"
             hAlign="Center"
             demandPopin="true" 
             minScreenWidth="Tablet" 
             importance="Medium">
                <Text id="idAttendanceIDText" text="{i18n>attendanceId}"  />
            </Column>
            <Column id="idDateColumn" hAlign="Center" importance="High">
                <Text id="idDateHeaderText" text="{i18n>DateText}" />
            </Column>
            <Column id="idCheckInColumn" hAlign="Center" importance="High">
                <Text id="idCheckInText" text="{i18n>checkInText}" />
            </Column>
            <Column id="idCheckOutColumn" hAlign="Center" importance="High">
                <Text id="idCheckOutText" text="{i18n>checkOutText}" />
            </Column>
            <Column id="idEmpIdColumn" hAlign="Center" 
             demandPopin="true" 
             minScreenWidth="Tablet" 
             importance="Low">
                <Text id="idOvertimeText" text="{i18n>overTimeText}" />
            </Column>
            <Column id="idPerformanceColumn" hAlign="Center" importance="High">
                <Text id="idPerformanceText" text="{i18n>performanceText}" />
            </Column>
        </columns>
        <items>
            <ColumnListItem id="idColumnListItem">
                <cells>
                <Text id="idAttendanceIdText" text="{employeeModel>attendanceId}" />
                <Text id="idDateText" text="{employeeModel>date}" />
                    <Text id="idCheckedInText" text="{employeeModel>checkedIn}" />
                    <Text id="idCheckedOutText" text="{employeeModel>checkedOut}" />
                <Text id="idOvertimeDataText" text="{employeeModel>overtime}" />
                <custom:EmployeePerformance
                 id="idRatingEmployeePerformance" 
                value="{employeeModel>rating}" />
                </cells>
            </ColumnListItem>
        </items>
    </Table>
  </Page>
</mvc:View>